APP_NAME=Pay Wallet API
APP_ENV=dev
PORT=8007
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/pay_wallet
FRANCECONNECT_BASE_URL=http://127.0.0.1:8001
FRANCECONNECT_ME_PATH=/me
FRANCECONNECT_SESSION_COOKIE_NAME=fc_monopoly_session
SERVICES_MONOPOLY_BASE_URL=http://127.0.0.1:8004
WALLET_JWT_SECRET=change-me-wallet-secret
WALLET_JWT_ALGORITHM=HS256
WALLET_ACCESS_TOKEN_TTL_MINUTES=120
CORS_ORIGINS_RAW=http://127.0.0.1:3002,http://localhost:3002
STRIPE_WEBHOOK_SHARED_SECRET=wallet-webhook-secret

